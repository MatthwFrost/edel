{
  "manifest_version": 3,
  "name": "Readel: Free, Modern Text to Speech",
  "version": "2.0.2",
  "description": "Modern, minimal, free text-to-speech. Hold Alt over any text to listen. No sign-up, no buttons, no menus.",
  "permissions": [
    "storage",
    "offscreen",
    "activeTab"
  ],
  "background": {
    "service_worker": "/build/background.js",
    "permissions": true,
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["build/inject.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "/assets/newicon.png",
    "32": "/assets/newicon.png",
    "48": "/assets/newicon.png",
    "128": "/assets/newicon.png"
  },
  "action": {
    "default_popup": "/scripts/popup/index.html"
  },
  "host_permissions": [
    "https://api.cartesia.ai/*",
    "<all_urls>"
  ]
}